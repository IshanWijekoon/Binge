{
  "name": "binge-workspace",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace @binge/api",
    "dev:web": "npm run dev --workspace @binge/web",
    "setup:local": "npm run db:migrate:local --workspace @binge/api",
    "dev": "concurrently \"npm run dev --workspace @binge/api\" \"npm run dev --workspace @binge/web\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}