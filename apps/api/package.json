{
  "name": "@binge/api",
  "version": "1.0.0",
  "description": "Cloudflare Workers backend for the Binge entertainment tracking platform.",
  "private": true,
  "main": "src/index.ts",
  "scripts": {
    "cf-typegen": "wrangler types",
    "typecheck": "tsc --noEmit",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply binge --local",
    "db:migrate:remote": "wrangler d1 migrations apply binge --remote",
    "admin:hash": "node scripts/admin-hash.mjs",
    "admin:set-secret": "node scripts/admin-set-secret.mjs",
    "deploy:safe": "node scripts/deploy-safe.mjs",
    "setup:env": "node scripts/setup-env.mjs",
    "backfill:snapshots": "node scripts/backfill-show-snapshots.mjs",
    "backfill:snapshots:local": "node scripts/backfill-show-snapshots.mjs --local",
    "import:tvtime": "node scripts/import-tvtime.mjs",
    "import:tvtime:local": "node scripts/import-tvtime.mjs --local",
    "import:tvtime:retry": "node scripts/import-tvtime.mjs --retry-failures",
    "sync:local": "node scripts/sync-local-d1.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "type": "module",
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.106.0"
  }
}
